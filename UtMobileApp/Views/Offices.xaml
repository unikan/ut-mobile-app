                            <buttons:SfButton.Content>
                                <Label HorizontalTextAlignment="Center" Text="adem.beadini@unite.edu.mk" FontAttributes="Bold" FontSize="19" TextColor="#303030" />
                            </buttons:SfButton.Content>
