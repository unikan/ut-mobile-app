<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UtMobileApp.Views.ForumP"
    xmlns="http://xamarin.com/schemas/2014/forms"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Converter="clr-namespace:UtMobileApp.Extensions"
    xmlns:border="clr-namespace:Syncfusion.XForms.Border;assembly=Syncfusion.Core.XForms"
    xmlns:d="http://xamarin.com/schemas/2014/forms/design"
    xmlns:listviews="clr-namespace:Syncfusion.ListView.XForms;assembly=Syncfusion.SfListView.XForms"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:buttons="clr-namespace:Syncfusion.XForms.Buttons;assembly=Syncfusion.Buttons.XForms"
    xmlns:inputLayout="clr-namespace:Syncfusion.XForms.TextInputLayout;assembly=Syncfusion.Core.XForms"
    xmlns:busyindicator="clr-namespace:Syncfusion.SfBusyIndicator.XForms;assembly=Syncfusion.SfBusyIndicator.XForms"
    mc:Ignorable="d"
    BackgroundColor="#5750f5">
    <ContentPage.Resources>
        <ResourceDictionary>
            <Converter:ButtonVisibility x:Key="ConvertButtonVisibility" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <ContentPage.Content>
        <AbsoluteLayout>
            <!-- HEADER -->
            <StackLayout Orientation="Horizontal"
                         HorizontalOptions="FillAndExpand"
                         VerticalOptions="FillAndExpand"
                         Margin="10, 0"
                         AbsoluteLayout.LayoutBounds="0.05, 0.03, 1, 0.13"
                         AbsoluteLayout.LayoutFlags="All">
                <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <buttons:SfButton 
                            Grid.Row="0" 
                            Grid.Column="0" 
                            HorizontalOptions="Start"
                            VerticalOptions="Center"
                            ShowIcon="True" 
                            BackgroundColor="Transparent"
                            CornerRadius="40"
                            WidthRequest="50"
                            HeightRequest="50"
                            Clicked="BtnBack_Clicked">
                        <buttons:SfButton.Content>
                            <Image Source="back.png"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   WidthRequest="20" 
                                   HeightRequest="20" />
                        </buttons:SfButton.Content>
                    </buttons:SfButton>
                    <busyindicator:SfBusyIndicator Grid.Column="1" 
                                                   Grid.Row="0"
                                                   x:Name="busyindicator"
                                                   ViewBoxHeight="70"
                                                   ViewBoxWidth="70"
                                                   TextColor="White"
                                                   TextSize="15"  
                                                   HorizontalOptions="CenterAndExpand"
                                                   VerticalOptions="CenterAndExpand">
                    </busyindicator:SfBusyIndicator>
                    <Label Grid.Row="0"
                           Grid.Column="1"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Start"
                           FontSize="Large"
                           FontAttributes="Bold"
                           MaxLines="1"
                           Text="Forum"
                           TextColor="White"
                           Opacity="0"
                           x:Name="label_forum"></Label>
                </Grid>
            </StackLayout>
            <border:SfBorder AbsoluteLayout.LayoutBounds="0, 1, 1, .85"
                             AbsoluteLayout.LayoutFlags="All"
                             CornerRadius="20, 20, 0, 0" 
                             BorderWidth="0"
                             BackgroundColor="White"
                             Padding="20"
                             x:Name="ForumContent">
                <StackLayout>
                    <buttons:SfButton BackgroundColor="#00bc67"
                                      Clicked="BtnExpand_Clicked"
                                      CornerRadius="5"
                                      FontSize="20"
                                      PressedBackgroundColor="#5a0aff"
                                      Text="Create Post"
                                      TextColor="White"
                                      HorizontalOptions="CenterAndExpand"
                                      VerticalOptions="Center"
                                      Margin="0, 10, 0, 0"/>
                    <StackLayout x:Name="PostInputs" Scale="0" IsVisible="False">
                        <inputLayout:SfTextInputLayout Hint="Title" 
                                                   ContainerType="Outlined"
                                                   FocusedColor="#3e00bc" 
                                                   UnfocusedColor="#545454">
                            <Entry x:Name="PostTitle" 
                               Completed="PostTitle_Completed"
                                   TextColor="Default"/>
                        </inputLayout:SfTextInputLayout>

                        <inputLayout:SfTextInputLayout Hint="Content"
                                                   ContainerType="Outlined"
                                                   FocusedColor="#3e00bc" 
                                                   UnfocusedColor="#545454">
                            <Editor x:Name="TextEditor"
                                AutoSize="TextChanges"/>
                        </inputLayout:SfTextInputLayout>

                        <StackLayout Orientation="Horizontal">
                            <buttons:SfButton BackgroundColor="#3e00bc"
                                      BorderColor="#3e00bc"
                                      BorderWidth="3"
                                      Clicked="btnPick_Clicked"
                                      CornerRadius="100"
                                      FontSize="20"
                                      PressedBackgroundColor="#5a0aff"
                                      Text="Upload Photo"
                                      TextColor="White"
                                      HorizontalOptions="Start"
                                      VerticalOptions="Center"
                                      HeightRequest="50"
                                      WidthRequest="160" />

                            <buttons:SfButton BackgroundColor="#3e00bc"
                                      BorderColor="#3e00bc"
                                      BorderWidth="3"
                                      Clicked="Post_Clicked"
                                      CornerRadius="100"
                                      FontSize="20"
                                      PressedBackgroundColor="#5a0aff"
                                      Text="Post"
                                      TextColor="White"
                                      HorizontalOptions="Start"
                                      VerticalOptions="Center"
                                      HeightRequest="50"
                                      WidthRequest="120" />

                            <Image x:Name="imgChoosed" Margin="10, 0, 0, 0" HeightRequest="50" WidthRequest="30" />
                        </StackLayout>
                    </StackLayout>

                    <listviews:SfListView
                                x:Name="forumList"
                                ItemSize="200"
                                ItemTapped="forumList_ItemTapped"
                                Opacity="1"
                                Padding="0, 10, 0, 0"
                                SelectionBackgroundColor="Transparent">
                        <listviews:SfListView.ItemTemplate>
                            <DataTemplate>
                                <Frame x:Name="frame" 
                                       HasShadow="False" 
                                       Padding="10" 
                                       Margin="2" 
                                       CornerRadius="5"
                                       BackgroundColor="#fbfbfe">
                                    <StackLayout>
                                        <Grid Margin="0, 0, 0, 20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"></ColumnDefinition>
                                                <ColumnDefinition Width="3*"></ColumnDefinition>
                                            </Grid.ColumnDefinitions>
                                            <border:SfBorder BorderColor="#4b36a6"
                                                         BorderWidth="1"
                                                         CornerRadius="50"
                                                         HeightRequest="50"
                                                         WidthRequest="50"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Center"
                                                         Grid.Column="0"
                                                         Grid.Row="0"
                                                         Grid.RowSpan="2">
                                                <Image Source="avatar.png" />
                                            </border:SfBorder>
                                            <Label HorizontalOptions="Start" 
                                               VerticalOptions="End"
                                               FontAttributes="Bold"
                                               FontSize="Medium"
                                               Text="{Binding Author}"
                                               Grid.Column="1"
                                               Grid.Row="0"/>
                                            <Label HorizontalOptions="Start"
                                               VerticalOptions="Start"
                                               FontSize="Small"
                                               Text="{Binding PostTime, StringFormat='{0:dddd, dd MMMM yyyy HH:mm}'}" 
                                               Grid.Column="1"
                                               Grid.Row="1"/>
                                        </Grid>
                                        <Label Text="{Binding PostTitle}"
                                               FontSize="Large"
                                               FontAttributes="Bold"/>
                                        <Label Text="{Binding PostContent}"
                                           FontSize="16"
                                           LineBreakMode="TailTruncation" />
                                    </StackLayout>
                                </Frame>
                            </DataTemplate>
                        </listviews:SfListView.ItemTemplate>
                    </listviews:SfListView>
                </StackLayout>
            </border:SfBorder>
            <border:SfBorder
                x:Name="NoInternetContent"
                Padding="20,0"
                AbsoluteLayout.LayoutBounds="0, 1, 1, .85"
                AbsoluteLayout.LayoutFlags="All"
                BackgroundColor="White"
                BorderWidth="0"
                CornerRadius="20, 20, 0, 0"
                IsVisible="False">
                <StackLayout HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand">
                    <Label
                        FontSize="32"
                        HorizontalOptions="CenterAndExpand"
                        Text="No internet, try again" />
                    <Button Clicked="Reload_Clicked" Text="Retry" />
                </StackLayout>
            </border:SfBorder>
            <StackLayout AbsoluteLayout.LayoutBounds="1, 1, 1, 0.05"
                         AbsoluteLayout.LayoutFlags="All"
                         x:Name="UpdateContent"
                         BackgroundColor="Red"
                         TranslationY="500">
                <buttons:SfButton x:Name="Btn_UpdatePosts"
                                  Text="Post added successfully, click here to refresh"
                                  BackgroundColor="Transparent"
                                  FontAttributes="Bold"
                                  VerticalOptions="CenterAndExpand"
                                  VerticalTextAlignment="Center"
                                  Clicked="Btn_UpdatePosts_Clicked">
                </buttons:SfButton>
            </StackLayout>
        </AbsoluteLayout>
    </ContentPage.Content>
</ContentPage>