<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UtMobileApp.Views.Unverified"
    xmlns="http://xamarin.com/schemas/2014/forms"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:d="http://xamarin.com/schemas/2014/forms/design"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    BackgroundColor="White">
    <ContentPage.Content>
        <StackLayout>
            <Label
                Margin="20,20,20,20"
                FontSize="25"
                HorizontalOptions="CenterAndExpand"
                Text="You haven't verified your email address yet , please verify your email addres to login."
                TextColor="#4682B4"
                VerticalOptions="CenterAndExpand" />



            <Button
                Margin="60,40"
                BackgroundColor="#4682B4"
                Clicked="GotoLogin"
                Text="Return to Login"
                TextColor="White" />

            <Button
                Margin="60,40"
                BackgroundColor="#4682B4"
                Clicked="VerifyAgain_Clicked"
                Text="Send Email Verification Again"
                TextColor="White" />

        </StackLayout>
    </ContentPage.Content>
</ContentPage>