<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="UtMobileApp.Login"
    xmlns="http://xamarin.com/schemas/2014/forms"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.XForms.Buttons;assembly=Syncfusion.Buttons.XForms"
    xmlns:d="http://xamarin.com/schemas/2014/forms/design"
    xmlns:inputLayout="clr-namespace:Syncfusion.XForms.TextInputLayout;assembly=Syncfusion.Core.XForms"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ContentPage.Content>
        <AbsoluteLayout>
            <Image Source="backgroundimg4.png"
                   Aspect="Fill"/>
            <!--  HEADER  -->
            <StackLayout
                Margin="10,0"
                AbsoluteLayout.LayoutBounds="0.05, 0.03, 1, 0.13"
                AbsoluteLayout.LayoutFlags="All"
                HorizontalOptions="FillAndExpand"
                Orientation="Horizontal"
                VerticalOptions="FillAndExpand">
                <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <buttons:SfButton
                        Grid.Row="0"
                        Grid.Column="0"
                        BackgroundColor="Transparent"
                        Clicked="BtnBack_Clicked"
                        CornerRadius="40"
                        HeightRequest="50"
                        HorizontalOptions="Start"
                        PressedBackgroundColor="Transparent"
                        ShowIcon="True"
                        VerticalOptions="Center"
                        WidthRequest="50">
                        <buttons:SfButton.Content>
                            <Image
                                HeightRequest="20"
                                HorizontalOptions="Center"
                                Source="back.png"
                                VerticalOptions="Center"
                                WidthRequest="20" />
                        </buttons:SfButton.Content>
                    </buttons:SfButton>
                </Grid>
            </StackLayout>

            <StackLayout
                x:Name="LoginContent"
                Padding="20,0"
                AbsoluteLayout.LayoutBounds="0, 1, 1, 1"
                AbsoluteLayout.LayoutFlags="All"
                VerticalOptions="CenterAndExpand">
                <Label
                    FontSize="35"
                    HorizontalOptions="Center"
                    Text="Welcome back"
                    TextColor="#eeeeee" />
                <Label FontSize="35" />

                <inputLayout:SfTextInputLayout
                    ContainerType="Outlined"
                    FocusedColor="#3e00bc"
                    Hint="Email"
                    UnfocusedColor="#eeeeee">
                    <Entry
                        x:Name="EmailInput"
                        Completed="EmailInput_Completed"
                        Keyboard="Email"
                        Placeholder="n.lastname3615111035@unite.edu.mk"
                        TextColor="#eeeeee" />
                </inputLayout:SfTextInputLayout>

                <inputLayout:SfTextInputLayout
                    ContainerType="Outlined"
                    EnablePasswordVisibilityToggle="True"
                    FocusedColor="#3e00bc"
                    Hint="Password"
                    UnfocusedColor="#eeeeee">
                    <Entry
                        x:Name="PasswordInput"
                        IsPassword="True"
                        TextColor="#eeeeee" />
                </inputLayout:SfTextInputLayout>
                <buttons:SfButton
                    x:Name="Btn_Login"
                    BackgroundColor="#3e00bc"
                    Clicked="Btn_Login_Clicked"
                    CornerRadius="100"
                    FontSize="20"
                    HeightRequest="60"
                    PressedBackgroundColor="#5a0aff"
                    Text="Log In"
                    TextColor="#eeeeee" />
                <buttons:SfButton
                    x:Name="Btn_ForgotPsw"
                    BackgroundColor="Transparent"
                    Clicked="Btn_ForgotPsw_Clicked"
                    FontSize="16"
                    Text="Forgot Password?"
                    TextColor="#eeeeee" />
            </StackLayout>
            <StackLayout
                x:Name="NoInternetContent"
                Padding="20,0"
                AbsoluteLayout.LayoutBounds="0, 1, 1, 1"
                AbsoluteLayout.LayoutFlags="All"
                IsVisible="False"
                VerticalOptions="CenterAndExpand">
                <Label
                    FontSize="32"
                    HorizontalOptions="CenterAndExpand"
                    Text="No internet, try again" />
                <Button Clicked="Reload_Clicked" Text="Retry" />
            </StackLayout>
        </AbsoluteLayout>
    </ContentPage.Content>
</ContentPage>