<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:d="http://xamarin.com/schemas/2014/forms/design"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:navigationdrawer="clr-namespace:Syncfusion.SfNavigationDrawer.XForms;assembly=Syncfusion.SfNavigationDrawer.XForms"
             xmlns:buttons="clr-namespace:Syncfusion.XForms.Buttons;assembly=Syncfusion.Buttons.XForms"
             xmlns:listviews="clr-namespace:Syncfusion.ListView.XForms;assembly=Syncfusion.SfListView.XForms"
             xmlns:border="clr-namespace:Syncfusion.XForms.Border;assembly=Syncfusion.Core.XForms"
             xmlns:busyindicator="clr-namespace:Syncfusion.SfBusyIndicator.XForms;assembly=Syncfusion.SfBusyIndicator.XForms"
             mc:Ignorable="d"
             x:Class="UtMobileApp.Views.MainPageStudent"
             BackgroundColor="White">
    <ContentPage.Padding>
        <OnPlatform x:TypeArguments="Thickness">
            <On Platform="Android">0, 10, 0, 0</On>
            <On Platform="iOS">0, 20, 0, 0</On>
        </OnPlatform>
    </ContentPage.Padding>
    <ContentPage.Content>

        <navigationdrawer:SfNavigationDrawer x:Name="navigationDrawer" 
                                             DrawerWidth ="300"
                                             Transition="Push"
                                             Duration="400"
                                             TouchThreshold="500"
                                             DrawerFooterHeight="30">
            <!-- DRAWER HEADER -->
            <navigationdrawer:SfNavigationDrawer.DrawerHeaderView>
                <Grid BackgroundColor="White">
                    <StackLayout VerticalOptions="Center" 
                                 HorizontalOptions="Center"
                                 Orientation="Horizontal">
                        <border:SfBorder BorderColor="Black" HorizontalOptions="Center" VerticalOptions="Center" CornerRadius="50" WidthRequest="50" HeightRequest="50" BorderWidth="1">
                            <Image Source="https://i5.walmartimages.com/asr/e9c1e290-55cb-4608-8edd-06b01ea694d0_1.cd6956088a6814bf191640ab06739752.png" />
                        </border:SfBorder>
                        <StackLayout>
                            <Label x:Name="label_flname" 
                               HorizontalOptions="Start" 
                               VerticalOptions="End"
                               FontAttributes="Bold"
                               FontSize="Medium"
                               Text="Filan Fisteki" />
                            <Label x:Name="label_email"
                                   HorizontalOptions="Start"
                                   VerticalOptions="Start"
                                   FontSize="Small"
                                   Text="f.filani3615111043" />
                        </StackLayout>
                    </StackLayout>
                </Grid>
            </navigationdrawer:SfNavigationDrawer.DrawerHeaderView>
            <!-- DRAWER CONTENT -->
            <navigationdrawer:SfNavigationDrawer.DrawerContentView>
                <StackLayout BackgroundColor="#f7f5fc"
                             Padding="20">
                    <buttons:SfButton Text="Profile" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="News" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent"
                                      Clicked="BtnNews_Clicked"/>
                    <buttons:SfButton Text="Calls" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" 
                                      Clicked="BtnCalls_Clicked"/>
                    <buttons:SfButton Text="Library" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Administration Offices" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Documents" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Discussion Forum" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Student Parliament" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Erasmus+" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Kujdesi për ty" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent"
                                      Clicked="BtnKujdesi_Clicked"/>
                    <buttons:SfButton Text="Facebook" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Contact Us" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                </StackLayout>
            </navigationdrawer:SfNavigationDrawer.DrawerContentView>
            <!-- FOOTER CONTENT -->
            <navigationdrawer:SfNavigationDrawer.DrawerFooterView>
                <Grid BackgroundColor="Salmon">
                    <StackLayout VerticalOptions="Center" 
                         HorizontalOptions="Center">
                        <Label Text="Powered by UNIKAN&#x1F970;"/>
                    </StackLayout>
                </Grid>
            </navigationdrawer:SfNavigationDrawer.DrawerFooterView>
            <navigationdrawer:SfNavigationDrawer.ContentView>
                <!-- MAIN CONTENT VIEW -->
                <AbsoluteLayout>
                    <!-- HEADER -->
                    <StackLayout Orientation="Horizontal"
                                    HorizontalOptions="FillAndExpand"
                                    VerticalOptions="FillAndExpand"
                                    Margin="10, 0"
                                    AbsoluteLayout.LayoutBounds="0, 0, 1, .1"
                                    AbsoluteLayout.LayoutFlags="All">
                        <Grid HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <buttons:SfButton 
                                Grid.Row="0" 
                                Grid.Column="0" 
                                HorizontalOptions="Start"
                                VerticalOptions="Center"
                                ShowIcon="True" 
                                BackgroundColor="White"
                                CornerRadius="40"
                                WidthRequest="50"
                                HeightRequest="50"
                                Clicked="HamburgerButton_Clicked">
                                <buttons:SfButton.Content>
                                    <Image Source="menu.png"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        WidthRequest="20" 
                                        HeightRequest="20" />
                                </buttons:SfButton.Content>
                            </buttons:SfButton>
                        </Grid>
                    </StackLayout>
                    <!-- Hello Message -->
                    <StackLayout Orientation="Horizontal" 
                                 AbsoluteLayout.LayoutBounds="0, .1, 1, .2"
                                 AbsoluteLayout.LayoutFlags="All"
                                 Padding="0, 10" 
                                 Margin="15, 0"
                                 HorizontalOptions="FillAndExpand"
                                 VerticalOptions="Center">
                        <Label>
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span FontSize="32" Text="Hello,&#x0a;" />
                                    <Span FontSize="32" FontAttributes="Bold" x:Name="label_name" Text="Filani" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </StackLayout>
                    <!-- Navigation Buttons -->
                    <StackLayout AbsoluteLayout.LayoutBounds="0, .4, 1, .35"
                                 AbsoluteLayout.LayoutFlags="All"
                                 Padding="0, 10"
                                 Margin="15, 0"
                                 HorizontalOptions="FillAndExpand"
                                 VerticalOptions="FillAndExpand">
                        <Grid RowSpacing="20" ColumnSpacing="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <buttons:SfButton Text="Lectures" 
                                              CornerRadius="20" 
                                              WidthRequest="75"
                                              HeightRequest="125"
                                              HorizontalTextAlignment="Start"
                                              VerticalTextAlignment="End"
                                              HorizontalOptions="FillAndExpand"
                                              Padding="15, 0,  0, 15"
                                              FontAttributes="Bold"
                                              FontSize="Medium"
                                              TextColor="White"
                                              Grid.Row="0" Grid.Column="0"
                                              BackgroundImage="lecturesbg.png"
                                              Clicked="BtnSchedule_Clicked">
                            </buttons:SfButton>
                            <buttons:SfButton Text="Midterms" 
                                              CornerRadius="20" 
                                              WidthRequest="75"
                                              HeightRequest="125"
                                              HorizontalTextAlignment="Start"
                                              VerticalTextAlignment="End"
                                              HorizontalOptions="FillAndExpand"
                                              Padding="15, 0,  0, 15"
                                              FontAttributes="Bold"
                                              FontSize="Medium"
                                              TextColor="White"
                                              Grid.Row="0" Grid.Column="1"
                                              BackgroundImage="midtermsbg.png">
                            </buttons:SfButton>
                            <buttons:SfButton Text="Exams" 
                                              CornerRadius="20" 
                                              WidthRequest="75"
                                              HeightRequest="125"
                                              HorizontalTextAlignment="Start"
                                              VerticalTextAlignment="End"
                                              HorizontalOptions="FillAndExpand"
                                              Padding="15, 0,  0, 15"
                                              FontAttributes="Bold"
                                              FontSize="Medium"
                                              TextColor="White"
                                              Grid.Row="1" Grid.Column="0"
                                              BackgroundImage="examsbg.png">
                            </buttons:SfButton>
                            <buttons:SfButton Text="Consultations" 
                                              CornerRadius="20" 
                                              WidthRequest="75"
                                              HeightRequest="125"
                                              HorizontalTextAlignment="Start"
                                              VerticalTextAlignment="End"
                                              HorizontalOptions="FillAndExpand"
                                              Padding="15, 0,  0, 15"
                                              FontAttributes="Bold"
                                              FontSize="Medium"
                                              TextColor="White"
                                              Grid.Row="1" Grid.Column="1"
                                              BackgroundImage="consultationsbg.png">
                            </buttons:SfButton>
                        </Grid>
                    </StackLayout>
                    <!-- Latest Announcements -->
                    <StackLayout AbsoluteLayout.LayoutBounds="0, 1, 1, .36"
                                 AbsoluteLayout.LayoutFlags="All"
                                 Padding="0, 10, 0, 0"
                                 Margin="15, 0"
                                 HorizontalOptions="FillAndExpand"
                                 VerticalOptions="StartAndExpand">

                        <busyindicator:SfBusyIndicator x:Name="busyindicator"
                                                       ViewBoxHeight="70"
                                                       ViewBoxWidth="70"
                                                       Title="Loading announcements..."
                                                       TextColor="Salmon"
                                                       TextSize="15" />
                        
                        <listviews:SfListView x:Name="announcementList" 
                                              ItemTapped="announcementList_ItemTapped"
                                              ItemSize="100"
                                              AutoFitMode="Height"
                                              SelectionBackgroundColor="Transparent"
                                              Opacity="0">
                            <listviews:SfListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="1" Margin="1">
                                        <Frame x:Name="frame" 
                                               HasShadow="True" 
                                               Padding="2" 
                                               Margin="2" 
                                               CornerRadius="10"
                                               BackgroundColor="#f7f5fc">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2.5*"></ColumnDefinition>
                                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                                </Grid.ColumnDefinitions>
                                                <Label Grid.Row="0"
                                                       Grid.Column="0"
                                                       HorizontalOptions="StartAndExpand"
                                                       VerticalOptions="CenterAndExpand"
                                                       FontSize="Medium"
                                                       FontAttributes="Bold"
                                                       TextType="Html"
                                                       Padding="10, 0, 0, 0"
                                                       Text="{Binding Title.Rendered}"></Label>
                                                <Grid Grid.Row="0"
                                                      Grid.Column="1"
                                                      HorizontalOptions="CenterAndExpand"
                                                      VerticalOptions="CenterAndExpand">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"></RowDefinition>
                                                        <RowDefinition Height="*"></RowDefinition>
                                                    </Grid.RowDefinitions>
                                                    <Label Grid.Row="0" 
                                                           HorizontalOptions="CenterAndExpand"
                                                           VerticalOptions="EndAndExpand"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="End"
                                                           Padding="0, 10, 0, 0"
                                                           Margin="0"
                                                           FontSize="Medium"
                                                           FontAttributes="Bold"
                                                           Text="{Binding Date, StringFormat='{0:dd}'}"></Label>
                                                    <Label Grid.Row="1" 
                                                           HorizontalOptions="CenterAndExpand"
                                                           VerticalOptions="Start"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Start"
                                                           Padding="0, 0, 0, 10"
                                                           Margin="0"
                                                           FontSize="Small"
                                                           FontAttributes="Italic"
                                                           Text="{Binding Date, StringFormat='{0:MMMM}'}"></Label>
                                                </Grid>
                                            </Grid>
                                        </Frame>
                                    </Grid>
                                </DataTemplate>
                            </listviews:SfListView.ItemTemplate>
                        </listviews:SfListView>
                    </StackLayout>
                </AbsoluteLayout>

            </navigationdrawer:SfNavigationDrawer.ContentView>
        </navigationdrawer:SfNavigationDrawer>

    </ContentPage.Content>
</ContentPage>