<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:d="http://xamarin.com/schemas/2014/forms/design"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:navigationdrawer="clr-namespace:Syncfusion.SfNavigationDrawer.XForms;assembly=Syncfusion.SfNavigationDrawer.XForms"
             xmlns:buttons="clr-namespace:Syncfusion.XForms.Buttons;assembly=Syncfusion.Buttons.XForms"
             xmlns:border="clr-namespace:Syncfusion.XForms.Border;assembly=Syncfusion.Core.XForms"
             xmlns:gradient="clr-namespace:Syncfusion.XForms.Graphics;assembly=Syncfusion.Core.XForms"
             mc:Ignorable="d"
             x:Class="UtMobileApp.Views.MainPageStudent"
             BackgroundColor="White">
    <ContentPage.Content>
        <navigationdrawer:SfNavigationDrawer x:Name="navigationDrawer" 
                                             DrawerWidth ="300"
                                             Transition="Push"
                                             Duration="400"
                                             TouchThreshold="200"
                                             DrawerFooterHeight="30">
            <!-- DRAWER HEADER -->
            <navigationdrawer:SfNavigationDrawer.DrawerHeaderView>
                <Grid BackgroundColor="#F5F5F5">
                    <StackLayout VerticalOptions="EndAndExpand" 
                                 HorizontalOptions="Center"
                                 Orientation="Horizontal">
                        <border:SfBorder BorderColor="Black" HorizontalOptions="Center" VerticalOptions="Center" CornerRadius="50" WidthRequest="50" HeightRequest="50" BorderWidth="1">
                            <Image Source="https://i5.walmartimages.com/asr/e9c1e290-55cb-4608-8edd-06b01ea694d0_1.cd6956088a6814bf191640ab06739752.png" />
                        </border:SfBorder>
                        <StackLayout>
                            <Label x:Name="label_flname" 
                               HorizontalOptions="Start" 
                               VerticalOptions="End"
                               FontAttributes="Bold"
                               FontSize="Medium"
                               Text="Filan Fisteki" />
                            <Label x:Name="label_email"
                                   HorizontalOptions="Start"
                                   VerticalOptions="Start"
                                   FontSize="Small"
                                   Text="f.filani3615111043" />
                        </StackLayout>
                    </StackLayout>
                </Grid>
            </navigationdrawer:SfNavigationDrawer.DrawerHeaderView>
            <!-- DRAWER CONTENT -->
            <navigationdrawer:SfNavigationDrawer.DrawerContentView>
                <StackLayout BackgroundColor="#F5F5F5"
                             Padding="20">
                    <buttons:SfButton Text="Profile" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="News" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent"
                                      Clicked="BtnNews_Clicked" />
                    <buttons:SfButton Text="Announcements" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" 
                                      Clicked="BtnAnnouncements_Clicked"/>
                    <buttons:SfButton Text="Calls" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" 
                                      Clicked="BtnCalls_Clicked" />
                    <buttons:SfButton Text="Library" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Administration Offices" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Documents" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Discussion Forum" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Student Parliament" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Erasmus+" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                    <buttons:SfButton Text="Kujdesi për ty" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent"
                                      Clicked="BtnKujdesi_Clicked" />
                    <buttons:SfButton Text="Facebook" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent"
                                      Clicked="BtnFacebook_Clicked" />
                    <buttons:SfButton Text="Contact Us" 
                                      TextColor="Black"
                                      FontSize="Medium"
                                      HorizontalTextAlignment="Start"
                                      BackgroundColor="Transparent" />
                </StackLayout>
            </navigationdrawer:SfNavigationDrawer.DrawerContentView>
            <!-- FOOTER CONTENT -->
            <navigationdrawer:SfNavigationDrawer.DrawerFooterView>
                <Grid BackgroundColor="#D35656">
                    <StackLayout VerticalOptions="Center" 
                         HorizontalOptions="Center">
                        <Label Text="Powered by UNIKAN&#x1F970;"/>
                    </StackLayout>
                </Grid>
            </navigationdrawer:SfNavigationDrawer.DrawerFooterView>
            <navigationdrawer:SfNavigationDrawer.ContentView>
                <!-- MAIN CONTENT VIEW -->
                <AbsoluteLayout>
                    <border:SfBorder AbsoluteLayout.LayoutBounds="0, 0, 1, 0.55"
                                     AbsoluteLayout.LayoutFlags="All"
                                     CornerRadius="0, 0, 150, 0" 
                                     BorderWidth="0">
                        <AbsoluteLayout>
                            <gradient:SfGradientView>
                                <gradient:SfGradientView.BackgroundBrush>
                                    <gradient:SfLinearGradientBrush>
                                        <gradient:SfLinearGradientBrush.GradientStops>
                                            <gradient:SfGradientStop Color="#484c7f" Offset="0.0" />
                                            <gradient:SfGradientStop Color="#719192" Offset="1.0" />
                                        </gradient:SfLinearGradientBrush.GradientStops>
                                    </gradient:SfLinearGradientBrush>
                                </gradient:SfGradientView.BackgroundBrush>
                            </gradient:SfGradientView>
                            <!-- Nav toggle -->
                            <buttons:SfButton x:Name="NavToggle" 
                                              ShowIcon="True" 
                                              CornerRadius="100"
                                              BackgroundColor="Transparent"
                                              Clicked="NavToggle_Clicked"
                                              Padding="0"
                                              AbsoluteLayout.LayoutBounds="0.05, 0.13, 50, 50"
                                              AbsoluteLayout.LayoutFlags="PositionProportional">
                                <buttons:SfButton.Content>
                                    <Image Source="menu.png"
                                           HeightRequest="25"
                                           WidthRequest="25"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </buttons:SfButton.Content>
                            </buttons:SfButton>

                            <Label AbsoluteLayout.LayoutBounds="0.1, 0.5, 0.5, 0.5"
                                   AbsoluteLayout.LayoutFlags="All"
                                   TextColor="White">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span FontSize="40" Text="Hello,&#x0a;" />
                                        <Span FontSize="40" FontAttributes="Bold" x:Name="label_name" Text="Filani" />
                                        <Span FontSize="20" x:Name="label_date" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Image Source="book.png"
                                   AbsoluteLayout.LayoutBounds="1, 0, 1, 1"
                                   AbsoluteLayout.LayoutFlags="All"
                                   TranslationX="50"
                                   TranslationY="-60" />
                        </AbsoluteLayout>
                    </border:SfBorder>
                    <!--<Button Text="Hey"
                            AbsoluteLayout.LayoutBounds="0.4, 0.55, 100, 50"
                            AbsoluteLayout.LayoutFlags="PositionProportional"></Button>-->
                    <StackLayout AbsoluteLayout.LayoutBounds="1, 1, 1, 0.45"
                                 AbsoluteLayout.LayoutFlags="All"
                                 HorizontalOptions="CenterAndExpand"
                                 VerticalOptions="CenterAndExpand">
                        <ScrollView Orientation="Horizontal" 
                                    HorizontalScrollBarVisibility="Never" Scrolled="ScrollView_Scrolled">
                            <StackLayout Orientation="Horizontal"
                                         Spacing="20"
                                         Padding="20">
                                <buttons:SfButton x:Name="BtnLectures"
                                                  Text="Lectures"  
                                                  CornerRadius="20" 
                                                  WidthRequest="200"
                                                  HeightRequest="300"
                                                  HorizontalTextAlignment="Center"
                                                  VerticalTextAlignment="Center"
                                                  Padding="20"
                                                  FontSize="24"
                                                  TranslationX="600"
                                                  Scale="0.95"
                                                  BackgroundImage="lectures.png"
                                                  Clicked="BtnLectures_Clicked" />
                                <buttons:SfButton x:Name="BtnMidterms"
                                                  Text="Midterms"  
                                                  CornerRadius="20" 
                                                  WidthRequest="200"
                                                  HeightRequest="300"
                                                  HorizontalTextAlignment="Center"
                                                  VerticalTextAlignment="Center"
                                                  Padding="20"
                                                  FontSize="24"
                                                  TranslationX="600"
                                                  Scale="0.95"
                                                  BackgroundImage="midterms.png"/>
                                <buttons:SfButton x:Name="BtnExams"
                                                  Text="Exams"  
                                                  CornerRadius="20" 
                                                  WidthRequest="200"
                                                  HeightRequest="300"
                                                  HorizontalTextAlignment="Center"
                                                  VerticalTextAlignment="Center"
                                                  Padding="20"
                                                  FontSize="24"
                                                  TranslationX="600"
                                                  Scale="0.95"
                                                  BackgroundImage="exams.png"/>
                                <buttons:SfButton x:Name="BtnConsultations"
                                                  Text="Consultations"  
                                                  CornerRadius="20" 
                                                  WidthRequest="200"
                                                  HeightRequest="300"
                                                  HorizontalTextAlignment="Center"
                                                  VerticalTextAlignment="Center"
                                                  Padding="20"
                                                  FontSize="24"
                                                  TranslationX="600"
                                                  Scale="0.95"
                                                  BackgroundImage="consultations.png"/>
                            </StackLayout>
                        </ScrollView>
                    </StackLayout>
                </AbsoluteLayout>
            </navigationdrawer:SfNavigationDrawer.ContentView>
        </navigationdrawer:SfNavigationDrawer>
    </ContentPage.Content>
</ContentPage>